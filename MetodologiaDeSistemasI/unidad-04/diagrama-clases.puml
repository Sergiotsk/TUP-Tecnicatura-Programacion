@startuml diagrama-clases-biblioteca

' Sistema: Biblioteca
' Unidad: 4 | Clase: 12

class Libro {
  - isbn: String
  - titulo: String
  - autor: String
  - disponible: Boolean
  + getInfo(): String
  + estaDisponible(): Boolean
}

class Socio {
  - nroSocio: int
  - nombre: String
  - email: String
  + realizarPrestamo(isbn: String): Prestamo
  + devolverLibro(prestamoId: int): void
}

class Prestamo {
  - id: int
  - fechaInicio: Date
  - fechaVencimiento: Date
  - devuelto: Boolean
  + renovar(): void
  + calcularMora(): double
}

class Catalogo {
  - libros: List<Libro>
  + buscarPorTitulo(titulo: String): List<Libro>
  + buscarPorAutor(autor: String): List<Libro>
  + agregarLibro(libro: Libro): void
}

Socio "1" -- "0..*" Prestamo : realiza
Libro "1" -- "0..*" Prestamo : es objeto de
Catalogo "1" *-- "0..*" Libro : contiene

@enduml
